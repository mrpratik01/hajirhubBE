# =============================================================================
#  HajirHub Backend — Environment Variables
#  Copy this file to .env and fill in your actual values.
#  NEVER commit .env to git.
# =============================================================================


# ─── Server ───────────────────────────────────────────────────────────────────

# Port the Express server listens on
PORT=3001


# ─── Supabase ─────────────────────────────────────────────────────────────────

# Your Supabase project URL — found in: Project Settings → API → Project URL
SUPABASE_URL=https://<your-project-ref>.supabase.co

# Anon/public key — safe to use on client, used here for auth token verification
# Found in: Project Settings → API → Project API keys → anon public
SUPABASE_ANON_KEY=eyJ...

# Service role key — has full DB access, bypasses RLS. KEEP THIS SECRET.
# Found in: Project Settings → API → Project API keys → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJ...


# ─── CORS ─────────────────────────────────────────────────────────────────────

# Allowed origins for CORS. Use * for development.
# For production set to your actual domains, comma-separated if needed.
# Example: https://app.hajirhub.com,https://admin.hajirhub.com
CORS_ORIGIN=*


# ─── Notifications ────────────────────────────────────────────────────────────

# Sparrow SMS (Nepal) — https://sparrowsms.com
# Used for: employee invite SMS, OTP fallback
SPARROW_SMS_TOKEN=your_sparrow_sms_token
SPARROW_SMS_FROM=HajirHub

# Twilio WhatsApp — https://twilio.com
# Used for: owner morning report, leave notifications
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Expo Push Notifications — no key needed (uses Expo's free push service)
# Just ensure employees have expo_push_token stored in users table


# ─── Optional / Future ────────────────────────────────────────────────────────

# OpenAI — only needed if AI features are added
# OPENAI_API_KEY=sk-...

# Node environment
NODE_ENV=development

# ─── Credentials Encryption ───────────────────────────────────────────────────
# 64-char hex string (32 bytes) used to encrypt employee temporary passwords.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# KEEP THIS SECRET — losing it means stored credentials cannot be decrypted.
CREDENTIALS_ENCRYPTION_KEY=your_64_char_hex_key_here
